# ─── Hostinger .htaccess for Kleza Landing Page ──────────────────────────────
# Upload this file to public_html as  .htaccess  (remove the .example extension)
# Keep this file OFF Git if it contains secrets.

# ─── SECURITY: Block direct HTTP access to .env ──────────────────────────────
<Files ".env">
  Order allow,deny
  Deny from all
</Files>

# ─── React SPA routing (Vite dist fallback) ───────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Allow direct access to real files (index.html, send-email.php, assets/)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else → React's index.html
  RewriteRule ^ index.html [L]
</IfModule>
